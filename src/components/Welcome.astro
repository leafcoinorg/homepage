---
// import { useState } from 'react';
import WeedBitLogo from '../assets/WeedBit.svg';
import softBackground from '../assets/background-soft.png';
---

<div class="min-h-screen bg-white text-[#222222] font-sans">
	<header class="container d-flex justify-content-between align-items-center py-4 border-success">
	  <img src={WeedBitLogo.src} width="210" alt="WeedBit" class="h-8" />
	  <nav class="d-flex align-items-center ms-auto">
		<div class="d-flex align-items-center">
		  <button id="lang-en" class="btn text-success p-0 mx-2 fs-3">🇬🇧</button>
		  <button id="lang-ru" class="btn text-success p-0 mx-2 fs-3">🇷🇺</button>
		  <button id="lang-th" class="btn text-success p-0 mx-2 fs-3">🇹🇭</button>
		</div>
	  </nav>
	</header>
  
	<main class="container py-20 px-4 text-center bg-white main-background">

	  <section class="mainhero d-flex align-items-center" style="min-height: 40vh; padding-top: 4rem; padding-bottom: 4rem;">
		<div class="container hero-container py-5">
		  <section class="mb-4 container">
			<h2 class="mdc-typography--headline3 mb-4">WeedBit — криптовалюта для каннабиса</h2>
			<p class="mdc-typography--body1 mb-6">WeedBit использует блокчейн-технологии для обеспечения прозрачных и надёжных транзакций, связанных с реальными активами ферм.</p>
			<div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
			  <a href="https://t.me/weed_bit" class="btn btn-success text-white fw-bold px-4 py-3">👉 Start using WeedBit</a>
			  <a href="https://github.com/weedbit/weedbit" class="btn btn-outline-success fw-bold px-4 py-3">🧪 View Technology</a> 
			  <a href="https://www.instagram.com/weedbit_" class="btn btn-outline-success fw-bold px-4 py-3">💸 Get Tokens</a>
			</div>
		  </section>
		</div>
	  </section>
  
	  <section class="container" style="min-height: 30vh; padding-top: 2rem;">
		<div class="row">
		  <div class="col-12 col-md-4 mb-4">
			<div class="p-5 rounded-4 border border-success border-opacity-25 shadow-lg">
			  <h3 class="mdc-typography--headline6 mb-3">Быстрые и прозрачные транзакции</h3>
			  <p class="mdc-typography--body2">Мгновенная верификация данных благодаря оракулам и блокчейн-технологиям.</p>
			</div>
		  </div>
		  <div class="col-12 col-md-4 mb-4">
			<div class="p-5 rounded-4 border border-success border-opacity-25 shadow-lg">
			  <h3 class="mdc-typography--headline6 mb-3">Обеспечение реальными активами</h3>
			  <p class="mdc-typography--body2">Каждый токен привязан к продукции и показателям реальных ферм.</p>
			</div>
		  </div>
		  <div class="col-12 col-md-4 mb-4">
			<div class="p-5 rounded-4 border border-success border-opacity-25 shadow-lg">
			  <h3 class="mdc-typography--headline6 mb-3">Инновационная интеграция IoT</h3>
			  <p class="mdc-typography--body2">Связь IoT-устройств с блокчейном через технологии Chainlink и Quorum.</p>
			</div>
		  </div>
		</div>
	  </section>
	</main>
  
	<!-- DONATE BLOCK START -->
	<section class="container mb-5" style="min-height: 20vh; padding-top: 2rem; padding-bottom: 2rem;">
	  <div class="bg-light border border-success rounded shadow p-4 d-flex flex-column align-items-center">
		<div class="d-flex align-items-center gap-2 mb-3">
		  <svg width="32" height="32" fill="none" viewBox="0 0 32 32"><circle cx="16" cy="16" r="16" fill="#2E7D32"/><text x="16" y="22" text-anchor="middle" font-size="18" fill="#fff" font-family="Arial, sans-serif">☘️</text></svg>
		  <span id="donate-title" class="h5 text-success fw-bold mb-0">Support WeedBit!</span>
		</div>
		<p id="donate-desc" class="text-center text-success mb-4">WeedBit is a community-funded project. Your donations help develop the website and infrastructure.</p>
		<a id="donate-btn" href="bitcoin:bc1qdr89zlyxtkdr8r2r9kmv077f84kteyjng2nm05" target="_blank" rel="noopener" class="btn btn-success px-4 py-2 rounded fw-semibold shadow-sm hover-bg-success">Make a Donation</a>
	  </div>
	</section>
	<!-- DONATE BLOCK END -->
	<footer class="px-4 py-6 bg-gray-200 text-center text-[#222222] mdc-typography--body2" style="padding-top: 2rem; padding-bottom: 2rem;">
	  <p>&copy; 2025 WeedBit. Все права защищены.</p>
	</footer>
</div>

<style>
	.main-background {
		background-image: url(${softBackground});
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}
	body, .font-sans {
	  font-family: ".SF Compact Rounded", sans-serif;
	}
</style>

<script>
	const translations = {
		en: {
		title: "Next Generation Digital currency for Cannabis Industry",
		description: "WeedBit is an innovative cryptocurrency backed by real farm assets.",
		start: "👉 Start using WeedBit",
		transparency: "🌱 Transparency",
		transparencyDesc: "Full transparency and verification of data thanks to blockchain technology and oracles.",
		reliability: "📈 Reliability",
		reliabilityDesc: "Each token is backed by real agricultural products and their indicators.",
		innovation: "🚀 Innovation",
		innovationDesc: "System based on Chainlink and Quorum linking IoT devices with blockchain.",
		footer: "© 2025 WeedBit. All rights reserved.",
		menuHome: "Home",
		menuAbout: "About",
		menuTokens: "Tokens",
		menuDocs: "Documentation",
		donateTitle: "Support WeedBit!",
		donateDesc: "WeedBit is a community-funded project. Your donations help develop the website and infrastructure.",
		donateButton: "Make a Donation"
		},
		ru: {
		title: "WeedBit — это новая криптовалюта для ферм каннабиса",
		description: "WeedBit — это инновационная криптовалюта, обеспеченная реальными активами фермерских хозяйств.",
		start: "👉 Начать использовать WeedBit",
		transparency: "🌱 Прозрачность",
		transparencyDesc: "Полная прозрачность и верификация данных благодаря блокчейн-технологии и оракулам.",
		reliability: "📈 Надёжность",
		reliabilityDesc: "Каждый токен подтверждён реальной сельскохозяйственной продукцией и её показателями.",
		innovation: "🚀 Инновации",
		innovationDesc: "Система на основе Chainlink и Quorum, связывающая IoT-устройства с блокчейном.",
		footer: "© 2025 WeedBit. Все права защищены.",
		menuHome: "Главная",
		menuAbout: "О проекте",
		menuTokens: "Токены",
		menuDocs: "Документация",
		donateTitle: "Поддержите WeedBit!",
		donateDesc: "WeedBit — проект, финансируемый сообществом. Ваши пожертвования помогут развитию сайта и инфраструктуры.",
		donateButton: "Сделать пожертвование"
		},
		th: {
		title: "สกุลเงินดิจิทัลยุคใหม่สำหรับอุตสาหกรรมกัญชา",
		description: "WeedBit คือสกุลเงินดิจิทัลนวัตกรรมที่ได้รับการสนับสนุนโดยสินทรัพย์จากฟาร์มจริง",
		start: "👉 เริ่มใช้ WeedBit",
		transparency: "🌱 ความโปร่งใส",
		transparencyDesc: "ความโปร่งใสและการตรวจสอบข้อมูลอย่างเต็มที่ด้วยเทคโนโลยีบล็อกเชนและออราเคิล",
		reliability: "📈 ความน่าเชื่อถือ",
		reliabilityDesc: "แต่ละโทเค็นได้รับการสนับสนุนโดยผลิตผลทางการเกษตรจริงและตัวชี้วัดของพวกมัน",
		innovation: "🚀 นวัตกรรม",
		innovationDesc: "ระบบที่ใช้ Chainlink และ Quorum เชื่อมต่ออุปกรณ์ IoT กับบล็อกเชน",
		footer: "© 2025 WeedBit สงวนลิขสิทธิ์",
		menuHome: "หน้าแรก",
		menuAbout: "เกี่ยวกับ",
		menuTokens: "โทเค็น",
		menuDocs: "เอกสาร",
		donateTitle: "สนับสนุน WeedBit!",
		donateDesc: "WeedBit เป็นโครงการที่ได้รับทุนจากชุมชน การบริจาคของคุณจะช่วยพัฒนาเว็บไซต์และโครงสร้างพื้นฐาน",
		donateButton: "บริจาค"
		}
	};

	function setLanguage(lang) {
		document.querySelector('h2').innerText = translations[lang].title;
		document.querySelector('section p').innerText = translations[lang].description;
		document.querySelector('section a').innerText = translations[lang].start;

		const cards = document.querySelectorAll('section.container > .row > div > div');
		cards[0].querySelector('h3').innerText = translations[lang].transparency;
		cards[0].querySelector('p').innerText = translations[lang].transparencyDesc;

		cards[1].querySelector('h3').innerText = translations[lang].reliability;
		cards[1].querySelector('p').innerText = translations[lang].reliabilityDesc;

		cards[2].querySelector('h3').innerText = translations[lang].innovation;
		cards[2].querySelector('p').innerText = translations[lang].innovationDesc;

		document.querySelector('footer p').innerText = translations[lang].footer;

		document.getElementById('menu-home').innerText = translations[lang].menuHome;
		document.getElementById('menu-about').innerText = translations[lang].menuAbout;
		document.getElementById('menu-tokens').innerText = translations[lang].menuTokens;
		document.getElementById('menu-docs').innerText = translations[lang].menuDocs;

		document.getElementById('donate-title').innerText = translations[lang].donateTitle;
		document.getElementById('donate-desc').innerText = translations[lang].donateDesc;
		document.getElementById('donate-btn').innerText = translations[lang].donateButton;

		localStorage.setItem('lang', lang);
	}

	document.getElementById('lang-en').onclick = () => setLanguage('en');
	document.getElementById('lang-ru').onclick = () => setLanguage('ru');
	document.getElementById('lang-th').onclick = () => setLanguage('th');

	// Загрузка языка по умолчанию (из localStorage или английский)
	const defaultLang = localStorage.getItem('lang') || 'en';
	setLanguage(defaultLang);
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/material-components-web/14.0.0/material-components-web.min.js"></script>
<script>
  mdc.autoInit();
</script>